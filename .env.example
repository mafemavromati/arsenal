# ─── Arsenal AI — Variáveis de Ambiente ───────────────────────────────────────
# Copie este arquivo para .env e preencha com seus valores reais
# No Railway, configure estas variáveis em: Settings → Variables

# Claude API (https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# Notion Integration Token (https://www.notion.so/my-integrations)
NOTION_TOKEN=secret_...

# ID do database criado no Notion
# Pegar da URL: notion.so/workspace/[ESTE-ID-AQUI]?v=...
NOTION_DATABASE_ID=cf74c33a76c7461abeeee23219c69dbd

# OpenAI API (https://platform.openai.com) — Whisper transcrição
OPENAI_API_KEY=sk-...

# Chave secreta para autenticar o webhook (gere uma string aleatória)
# Exemplo: openssl rand -hex 32
WEBHOOK_SECRET=gere-uma-chave-aleatoria-aqui

# Cookies do Instagram em formato Netscape (opcional)
# Necessário para baixar Reels do Instagram via yt-dlp
# Exporte do browser usando extensão "Get cookies.txt LOCALLY"
INSTAGRAM_COOKIES=
